{% extends 'base.html.twig' %}
{% block title %}{{ site_name }} &mdash; {{ trans('nav.forum_index') }}{% endblock %}
{% block head %}
    <meta property="og:site_name" content="{{ site_name }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ site_name }}">
    <meta property="og:url" content="{{ absolute_url(path('/')) }}">
    {% if feeds_enabled %}
        <link rel="alternate" type="application/rss+xml" title="{{ site_name }} — RSS" href="{{ absolute_url('/feed.rss') }}">
        <link rel="alternate" type="application/atom+xml" title="{{ site_name }} — Atom" href="{{ absolute_url('/feed.atom') }}">
        <link rel="alternate" type="application/feed+json" title="{{ site_name }} — JSON Feed" href="{{ absolute_url('/feed.json') }}">
    {% endif %}
    {{ json_ld(json_ld) }}
{% endblock %}

{% block content %}
<div class="page-header">
    <h1 class="forum-index-title">{{ site_name }}</h1>
    {% if feeds_enabled or can_moderate or can_moderate_users %}
        <div class="forum-header-actions">
            {% if feeds_enabled %}
                <a href="{{ path('/feed.rss') }}" class="btn-feed"><i class="fa fa-rss"></i>{{ trans('forum.feed_link') }}</a>
            {% endif %}
            {% if can_moderate or can_moderate_users %}
                <div class="mod-dropdown">
                    <button type="button" class="btn-mod mod-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                        <i class="fa fa-gavel"></i>{{ trans('mod.moderate') }} <i class="fa fa-caret-down"></i>
                    </button>
                    <div class="mod-dropdown-menu">
                        {% if can_moderate %}
                            <a href="{{ path('/moderate/queue') }}">{{ trans('mod.queue') }}</a>
                            <a href="{{ path('/moderate/reports') }}">{{ trans('mod.reports_title') }}</a>
                        {% endif %}
                        {% if can_moderate_users %}
                            <a href="{{ path('/moderate/users') }}">{{ trans('mod.users_queue') }}</a>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
    {% endif %}
</div>

{% if announcements %}
    {% include 'announcements/_box.html.twig' %}
{% endif %}

{% if tree is empty %}
    <p>{{ trans('forum_list.no_forums') }}</p>
{% else %}
    {% import 'forum/_macros.html.twig' as macros %}
    {{ macros.forum_list(tree) }}
{% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ forum.name }} &mdash; {{ site_name }}{% endblock %}
{% block head %}
    {% set canonical_url = absolute_url(pagination_url(base_url, page)) %}
    <link rel="canonical" href="{{ canonical_url }}">
    {% if page > 1 %}<link rel="prev" href="{{ absolute_url(pagination_url(base_url, page - 1)) }}">{% endif %}
    {% if page < pages %}<link rel="next" href="{{ absolute_url(pagination_url(base_url, page + 1)) }}">{% endif %}
    <meta property="og:site_name" content="{{ site_name }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ forum.name }}">
    {% if forum.description %}<meta property="og:description" content="{{ forum.description|striptags }}">{% endif %}
    <meta property="og:url" content="{{ canonical_url }}">
    {% if feeds_enabled %}
        <link rel="alternate" type="application/rss+xml" title="{{ forum.name }} — RSS" href="{{ absolute_url('/forum/' ~ forum.forum_id ~ '/feed.rss') }}">
        <link rel="alternate" type="application/atom+xml" title="{{ forum.name }} — Atom" href="{{ absolute_url('/forum/' ~ forum.forum_id ~ '/feed.atom') }}">
        <link rel="alternate" type="application/feed+json" title="{{ forum.name }} — JSON Feed" href="{{ absolute_url('/forum/' ~ forum.forum_id ~ '/feed.json') }}">
    {% endif %}
    {{ json_ld(json_ld) }}
{% endblock %}

{% block content %}
<nav class="breadcrumb" aria-label="{{ trans('nav.breadcrumb') }}">
    <a href="{{ path('/') }}">{{ trans('nav.forum_index') }}</a> &rsaquo; {{ forum.name }}
</nav>

<div class="forum-header">
    <h1 id="forum-heading" class="forum-title">{{ forum.name }}</h1>
    {% if forum.description %}<p class="forum-desc">{{ forum.description|raw }}</p>{% endif %}
    <div class="forum-header-actions">
        {% if can_post %}
            <a href="{{ path('/forum/' ~ forum.forum_id ~ '/post') }}" class="btn-post"><i class="fa fa-pencil-square-o"></i>{{ trans('forum.new_thread') }}</a>
        {% endif %}
        {% if user is defined and user %}
            <form method="post" action="{{ path('/forum/' ~ forum.forum_id ~ '/mark-read') }}" class="form-inline">
                {{ csrf_field() }}
                <button type="submit" class="btn-mark-read"><i class="fa fa-check-square-o"></i>{{ trans('forum.mark_read') }}</button>
            </form>
        {% endif %}
        {% if feeds_enabled %}
            <a href="{{ path('/forum/' ~ forum.forum_id ~ '/feed.rss') }}" class="btn-feed"><i class="fa fa-rss"></i>{{ trans('forum.feed_link') }}</a>
        {% endif %}
        {% if can_moderate %}
            <div class="mod-dropdown">
                <button type="button" class="btn-mod mod-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                    <i class="fa fa-gavel"></i>{{ trans('mod.moderate') }} <i class="fa fa-caret-down"></i>
                </button>
                <div class="mod-dropdown-menu">
                    <a href="{{ path('/moderate/queue') }}">{{ trans('mod.queue') }}</a>
                    <a href="{{ path('/moderate/reports') }}">{{ trans('mod.reports_title') }}</a>
                </div>
            </div>
        {% endif %}
    </div>
</div>

{% if announcements %}
    {% include 'announcements/_box.html.twig' %}
{% endif %}

{% if threads is empty %}
    <p>{{ trans('forum.no_threads') }}
        {% if can_post %}<a href="{{ path('/forum/' ~ forum.forum_id ~ '/post') }}"><i class="fa fa-pencil-square-o"></i>{{ trans('forum.start_one') }}</a>{% endif %}
    </p>
{% else %}
    <table class="tbl-boxed thread-list" aria-labelledby="forum-heading">
        <thead>
            <tr>
                <th scope="col" class="col-subject">{{ trans('forum.col_subject') }}</th>
                <th scope="col" class="col-replies">{{ trans('forum.col_posts') }}</th>
                <th scope="col" class="col-lastpost">{{ trans('forum.col_last_post') }}</th>
            </tr>
        </thead>
        <tbody>
        {% for thread in threads %}
            <tr class="thread-row{{ thread.sort < 2 ? ' thread-sticky' : '' }}">
                <td class="col-subject">
                    <div class="thread-subject-row">
                        <i class="fa fa-comment-o thread-icon"></i>
                        <div class="thread-subject-info">
                            {% if thread.sort == 1 %}<span class="sticky-badge">{{ trans('forum.sticky') }}</span> {% endif %}
                            {% if thread.closed %}<span class="closed-badge">{{ trans('forum.closed') }}</span> {% endif %}
                            <a href="{{ path('/forum/' ~ forum.forum_id ~ '/thread/' ~ thread.message_id) }}">
                                {{- thread.subject -}}
                            </a>
                            {% if thread_new_counts[thread.message_id] is defined %}
                                <span class="new-badge">{{ thread_new_counts[thread.message_id] }} {{ trans('forum.new') }}</span>
                            {% endif %}
                            <small class="thread-author">{{ trans('forum.by') }}
                                {% if thread.user_id > 0 %}
                                    <a href="{{ path('/user/' ~ thread.user_id) }}">{{ thread.author }}</a>
                                {% else %}
                                    {{ thread.author }}
                                {% endif %}
                            </small>
                        </div>
                    </div>
                </td>
                <td class="col-replies">{{ thread.thread_count }}</td>
                <td class="col-lastpost">
                    {% if thread.recent_author %}
                        <span class="lastpost-time">{{ thread.modifystamp|relative_time }}</span>
                        <small class="lastpost-by">{{ trans('forum.by') }}
                            {% if thread.recent_user_id > 0 %}
                                <a href="{{ path('/user/' ~ thread.recent_user_id) }}">{{ thread.recent_author }}</a>
                            {% else %}
                                {{ thread.recent_author }}
                            {% endif %}
                        </small>
                    {% else %}
                        {{ thread.modifystamp|relative_time }}
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {% include '_pagination.html.twig' %}
{% endif %}
{% endblock %}

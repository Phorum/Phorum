{% macro forum_list(items) %}
    {% import _self as self %}
    <table class="tbl-boxed forum-list">
        <caption class="visually-hidden">{{ trans('forum_list.col_forum') }}</caption>
        <tbody>
        {% set ungrouped_header_shown = false %}
        {% for forum in items %}
            {% if forum.folder_flag %}
                {{ self.group_header(forum.name, path('/forum/' ~ forum.forum_id)) }}
                {% set ungrouped_header_shown = false %}
                {% if forum.children %}
                    {{ self.forum_rows(forum.children) }}
                {% endif %}
            {% else %}
                {% if not ungrouped_header_shown %}
                    {{ self.group_header(trans('forum_list.col_forum')) }}
                    {% set ungrouped_header_shown = true %}
                {% endif %}
                {{ self.forum_row(forum, false) }}
            {% endif %}
        {% endfor %}
        </tbody>
    </table>
{% endmacro %}

{# Repeated per folder (using the folder's name) and once before any
   top-level forums that aren't in a folder (using the generic "Forum"
   column label) — mirrors the Phorum 6 index, which repeats the
   Posts/Threads/Last Post column header bar for every group. #}
{% macro group_header(label, url = null) %}
    <tr class="forum-group-header">
        <th scope="col" class="col-forum">
            {%- if url -%}
                <a href="{{ url }}"><i class="fa fa-folder"></i>{{ label }}</a>
            {%- else -%}
                {{ label }}
            {%- endif -%}
        </th>
        <th scope="col" class="col-posts">{{ trans('forum_list.col_posts') }}</th>
        <th scope="col" class="col-threads">{{ trans('forum_list.col_threads') }}</th>
        <th scope="col" class="col-last">{{ trans('forum_list.col_last') }}</th>
    </tr>
{% endmacro %}

{% macro forum_rows(forums) %}
    {% import _self as self %}
    {% for forum in forums %}
        {{ self.forum_row(forum, true) }}
    {% endfor %}
{% endmacro %}

{% macro forum_row(forum, indented) %}
    {% set indented = indented ?? false %}
    <tr class="forum-row{{ indented ? ' forum-row--indented' : '' }}">
        <td class="col-forum">
            <a href="{{ path('/forum/' ~ forum.forum_id) }}">{{ forum.name }}</a>
            {% if forum.description %}<br><small class="forum-desc">{{ forum.description|raw }}</small>{% endif %}
        </td>
        <td class="col-posts">{{ forum.message_count }}</td>
        <td class="col-threads">{{ forum.thread_count }}</td>
        <td class="col-last">{{ forum.last_post_time ? forum.last_post_time|relative_time : '&mdash;'|raw }}</td>
    </tr>
{% endmacro %}

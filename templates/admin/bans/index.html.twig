{% extends 'admin/base.html.twig' %}
{% block title %}Ban List{% endblock %}

{% block content %}
<div class="row valign-wrapper">
    <div class="col s8"><h4 class="page-title" style="margin:0">Ban List</h4></div>
    <div class="col s4 right-align">
        <a href="{{ path('/admin/bans/create') }}" class="btn green darken-3 waves-effect waves-light">
            <i class="material-icons left">add</i>New
        </a>
    </div>
</div>

{% if bans is empty %}
    <p class="grey-text">No ban entries yet.</p>
{% else %}
    <div class="card z-depth-1">
        <table class="striped responsive-table">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Forum</th>
                    <th>Value</th>
                    <th>Regex</th>
                    <th>Comments</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            {% for ban in bans %}
                <tr>
                    <td>{{ types[ban.type]|default('Unknown') }}</td>
                    <td>{{ ban.forum_id == 0 ? 'All Forums' : forum_names[ban.forum_id]|default('#' ~ ban.forum_id) }}</td>
                    <td><code>{{ ban.string|e }}</code></td>
                    <td>{{ ban.pcre ? 'Yes' : 'No' }}</td>
                    <td>{{ ban.comments|e }}</td>
                    <td class="admin-actions">
                        <a href="{{ path('/admin/bans/' ~ ban.id ~ '/edit') }}" class="btn-small waves-effect waves-light green lighten-1">
                            <i class="material-icons tiny">edit</i>
                        </a>
                        <a href="{{ path('/admin/bans/' ~ ban.id ~ '/delete') }}" class="btn-small waves-effect waves-light red lighten-1">
                            <i class="material-icons tiny">remove_circle</i>
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}

{% extends 'admin/base.html.twig' %}
{% block title %}{{ is_new ? 'New Custom Field' : 'Edit: ' ~ config.name }}{% endblock %}

{% block content %}
<div class="row valign-wrapper" style="margin-bottom:8px">
    <div class="col s12">
        <a href="{{ path('/admin/custom-fields') }}" class="grey-text">
            <i class="material-icons tiny">arrow_back</i> Custom Fields
        </a>
        <h4 class="page-title" style="margin-top:8px">
            {{ is_new ? 'New Custom Field' : 'Edit: ' ~ config.name|e }}
        </h4>
    </div>
</div>

{% include 'admin/_alerts.html.twig' %}

<div class="card z-depth-1">
    <div class="card-content">
        <form method="post">
            {{ csrf_field() }}

            <div class="row">
                <div class="input-field col s12 m6">
                    {% if is_new %}
                        <input id="name" type="text" name="name"
                               value="{{ config.name|e }}"
                               pattern="[a-zA-Z][a-zA-Z0-9_]*" maxlength="50" required>
                        <label for="name" class="{{ config.name ? 'active' : '' }}">Field Name</label>
                        <span class="helper-text">Letters, numbers, underscores. Must start with a letter. Used as the internal identifier.</span>
                    {% else %}
                        <input type="text" value="{{ config.name|e }}" disabled class="grey-text">
                        <label class="active">Field Name (cannot change after creation)</label>
                    {% endif %}
                </div>
                <div class="input-field col s12 m6">
                    <input id="length" type="number" name="length"
                           value="{{ config.length ?: 255 }}" min="1" max="65000" required>
                    <label for="length" class="active">Max Length (characters)</label>
                </div>
            </div>

            {% if is_new %}
            <div class="row">
                <div class="input-field col s12 m6">
                    <select name="field_type" id="field_type">
                        {% for type_id, type_label in type_labels %}
                            <option value="{{ type_id }}"{{ config.field_type == type_id ? ' selected' : '' }}>{{ type_label }}</option>
                        {% endfor %}
                    </select>
                    <label for="field_type">Field Type</label>
                </div>
            </div>
            {% else %}
            <div class="row">
                <div class="input-field col s12 m6">
                    <input type="text" value="{{ type_labels[config.field_type] ?? config.field_type }}" disabled class="grey-text">
                    <label class="active">Field Type (cannot change after creation)</label>
                </div>
            </div>
            {% endif %}

            <div class="row">
                <div class="col s12 m6">
                    <label>
                        <input type="checkbox" name="html_disabled" value="1"
                               {{ config.html_disabled ? 'checked' : '' }}>
                        <span>Escape HTML on display (recommended — prevents XSS)</span>
                    </label>
                </div>
                {% if is_new or config.field_type == 1 %}
                <div class="col s12 m6" id="show_in_admin_wrap">
                    <label>
                        <input type="checkbox" name="show_in_admin" value="1"
                               {{ config.show_in_admin ? 'checked' : '' }}>
                        <span>Show in admin user editor</span>
                    </label>
                </div>
                {% endif %}
            </div>

            {% if is_new %}
            <script>
            document.getElementById('field_type').addEventListener('change', function () {
                var wrap = document.getElementById('show_in_admin_wrap');
                wrap.style.display = this.value === '1' ? '' : 'none';
            });
            // Set initial state in case the page loaded with a non-User type selected
            (function () {
                var wrap = document.getElementById('show_in_admin_wrap');
                var sel  = document.getElementById('field_type');
                wrap.style.display = sel.value === '1' ? '' : 'none';
            })();
            </script>
            {% endif %}

            <div class="row">
                <div class="col s12 right-align">
                    <a href="{{ path('/admin/custom-fields') }}" class="btn-flat waves-effect">Cancel</a>
                    <button type="submit" class="btn green darken-3 waves-effect waves-light">
                        <i class="material-icons left">save</i>{{ is_new ? 'Create' : 'Save' }}
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}

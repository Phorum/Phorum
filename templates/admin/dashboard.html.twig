{% extends 'admin/base.html.twig' %}
{% block title %}Dashboard{% endblock %}

{% block content %}
<h4 class="page-title">Dashboard</h4>

<!-- Stat cards -->
<div class="row">
    <div class="col s12 m6 l3">
        <div class="card stat-card z-depth-1">
            <div class="card-content">
                <div class="stat-value">{{ stats.users }}</div>
                <div class="stat-label"><i class="material-icons tiny">people</i> Active Users</div>
            </div>
        </div>
    </div>
    <div class="col s12 m6 l3">
        <div class="card stat-card z-depth-1">
            <div class="card-content">
                <div class="stat-value">{{ stats.posts }}</div>
                <div class="stat-label"><i class="material-icons tiny">message</i> Posts</div>
            </div>
        </div>
    </div>
    <div class="col s12 m6 l3">
        <div class="card stat-card z-depth-1">
            <div class="card-content">
                <div class="stat-value">{{ stats.forums }}</div>
                <div class="stat-label"><i class="material-icons tiny">forum</i> Forums</div>
            </div>
        </div>
    </div>
    <div class="col s12 m6 l3">
        <div class="card stat-card {{ stats.unapproved > 0 ? 'warn' : '' }} z-depth-1">
            <div class="card-content">
                <div class="stat-value">{{ stats.unapproved }}</div>
                <div class="stat-label"><i class="material-icons tiny">pending</i> Unapproved Posts</div>
            </div>
            {% if stats.unapproved > 0 %}
            <div class="card-action">
                <a href="{{ path('/search?search=&match_type=ALL&match_dates=0') }}" class="orange-text">Review</a>
            </div>
            {% endif %}
        </div>
    </div>
</div>

<div class="row">
    <!-- Recent users -->
    <div class="col s12 m6">
        <div class="card z-depth-1">
            <div class="card-content">
                <span class="card-title">Recent Registrations</span>
                {% if recent_users is empty %}
                    <p class="grey-text">No users yet.</p>
                {% else %}
                    <table class="striped">
                        <thead><tr><th>Username</th><th>Joined</th></tr></thead>
                        <tbody>
                        {% for u in recent_users %}
                            <tr>
                                <td>
                                    <a href="{{ path('/admin/users/' ~ u.user_id ~ '/edit') }}">{{ u.username|e }}</a>
                                    {% if u.admin %}<span class="badge-admin">admin</span>{% endif %}
                                </td>
                                <td style="font-size:.85rem">{{ u.date_added|datestamp }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
            <div class="card-action">
                <a href="{{ path('/admin/users') }}" class="green-text">All Users →</a>
            </div>
        </div>
    </div>

    <!-- Recent posts -->
    <div class="col s12 m6">
        <div class="card z-depth-1">
            <div class="card-content">
                <span class="card-title">Recent Posts</span>
                {% if recent_posts is empty %}
                    <p class="grey-text">No posts yet.</p>
                {% else %}
                    <table class="striped">
                        <thead><tr><th>Subject</th><th>By</th></tr></thead>
                        <tbody>
                        {% for p in recent_posts %}
                            <tr>
                                <td>
                                    <a href="{{ path('/forum/' ~ p.forum_id ~ '/thread/' ~ p.thread) }}#msg-{{ p.message_id }}" target="_blank">
                                        {{ p.subject|e|slice(0,50) }}
                                    </a>
                                </td>
                                <td style="font-size:.85rem">{{ p.author|e }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

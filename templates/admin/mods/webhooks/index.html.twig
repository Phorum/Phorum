{% extends 'admin/base.html.twig' %}
{% block title %}Webhooks{% endblock %}

{% block content %}
<div class="row valign-wrapper">
    <div class="col s8"><h4 class="page-title" style="margin:0">Webhooks</h4></div>
    <div class="col s4 right-align">
        <a href="{{ path('/admin/webhooks/create') }}" class="btn green darken-3 waves-effect waves-light">
            <i class="material-icons left">add</i>New
        </a>
    </div>
</div>

{% if webhooks is empty %}
    <p class="grey-text">No webhooks configured yet.</p>
{% else %}
    <div class="card z-depth-1">
        <table class="striped responsive-table">
            <thead>
                <tr>
                    <th>URL</th>
                    <th>Events</th>
                    <th>Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            {% for webhook in webhooks %}
                <tr>
                    <td><code>{{ webhook.url|e }}</code></td>
                    <td>
                        {% for name in events_by_id[webhook.id]|default([]) %}
                            <span class="chip">{{ events[name]|default(name) }}</span>
                        {% endfor %}
                    </td>
                    <td>{{ webhook.active ? 'Yes' : 'No' }}</td>
                    <td class="admin-actions">
                        <a href="{{ path('/admin/webhooks/' ~ webhook.id ~ '/edit') }}" class="btn-small waves-effect waves-light green lighten-1">
                            <i class="material-icons tiny">edit</i>
                        </a>
                        <a href="{{ path('/admin/webhooks/' ~ webhook.id ~ '/delete') }}" class="btn-small waves-effect waves-light red lighten-1">
                            <i class="material-icons tiny">remove_circle</i>
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}

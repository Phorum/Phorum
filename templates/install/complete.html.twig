<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Installation Complete — Phorum</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <style>
        body { background: #f5f5f5; }
        nav  { background-color: #2e7d32; }
        .brand-logo { font-size: 1.4rem !important; }
        .card { margin-top: 48px; text-align: center; }
        .big-icon { font-size: 72px; color: #2e7d32; }
    </style>
</head>
<body>
<nav>
    <div class="nav-wrapper container">
        <span class="brand-logo">Phorum Installer</span>
    </div>
</nav>

<div class="container">
    <div class="card">
        <div class="card-content">
            <i class="material-icons big-icon">check_circle</i>
            <h4>Installation Complete</h4>
            <p class="grey-text">
                The database schema has been created and your admin account is ready.
            </p>
            <div style="margin-top: 24px;">
                <a href="{{ path('/') }}" class="btn green darken-3 waves-effect waves-light" style="margin-right: 12px;">
                    <i class="material-icons left">home</i>Go to Forum
                </a>
                <a href="{{ path('/admin/login') }}" class="btn blue darken-2 waves-effect waves-light">
                    <i class="material-icons left">admin_panel_settings</i>Admin Panel
                </a>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Phorum Installer</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <style>
        body  { background: #f5f5f5; }
        .brand-logo { font-size: 1.4rem !important; }
        nav   { background-color: #2e7d32; }
        .card { margin-top: 24px; }
        .req-row td { padding: 6px 8px; }
        .chip.ok   { background-color: #e8f5e9; color: #2e7d32; }
        .chip.fail { background-color: #ffebee; color: #c62828; }
    </style>
</head>
<body>
<nav>
    <div class="nav-wrapper container">
        <span class="brand-logo">Phorum Installer</span>
    </div>
</nav>

<div class="container">

    {# Requirements #}
    <div class="card">
        <div class="card-content">
            <span class="card-title">Requirements</span>
            <table class="req-row">
                <tbody>
                {% for req in requirements %}
                <tr>
                    <td>{{ req.name }}</td>
                    <td><span class="chip {{ req.ok ? 'ok' : 'fail' }}">{{ req.ok ? req.value : (req.ok ? req.value : 'failed') }}</span></td>
                    <td>
                        {% if req.ok %}
                            <i class="material-icons green-text">check_circle</i>
                        {% else %}
                            <i class="material-icons red-text">error</i>
                        {% endif %}
                    </td>
                </tr>
                {% if not req.ok %}
                <tr>
                    <td colspan="3">
                        <pre style="margin:0 0 8px 0;padding:8px;background:#ffebee;color:#c62828;font-size:0.85rem;white-space:pre-wrap;word-break:break-all;border-radius:4px;">{{ req.value }}</pre>
                    </td>
                </tr>
                {% endif %}
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if not can_install %}
    <div class="card red lighten-4">
        <div class="card-content red-text text-darken-3">
            <strong>Fix the requirements above before continuing.</strong>
            Make sure <code>etc/config.ini</code> and <code>etc/phorum.php</code>
            exist (copy from the <code>.example</code> files) and that the database
            credentials are correct.
        </div>
    </div>
    {% else %}

    {# Errors #}
    {% if errors %}
    <div class="card red lighten-4">
        <div class="card-content">
            <span class="card-title red-text text-darken-3">Please fix the following</span>
            <ul class="browser-default">
                {% for e in errors %}<li>{{ e }}</li>{% endfor %}
            </ul>
        </div>
    </div>
    {% endif %}

    {# Install form #}
    <div class="card">
        <div class="card-content">
            <span class="card-title">Site &amp; Admin Setup</span>
            <form method="post" action="{{ path('/install') }}">
                {{ csrf_field() }}

                <div class="row">
                    <div class="input-field col s12 m6">
                        <input id="site_name" name="site_name" type="text"
                               value="{{ values.site_name|e }}" required>
                        <label for="site_name">Site Name</label>
                    </div>
                </div>

                <p class="grey-text">Admin Account</p>

                <div class="row">
                    <div class="input-field col s12 m4">
                        <input id="admin_username" name="admin_username" type="text"
                               value="{{ values.admin_username|e }}" required>
                        <label for="admin_username">Username</label>
                    </div>
                    <div class="input-field col s12 m4">
                        <input id="admin_email" name="admin_email" type="email"
                               value="{{ values.admin_email|e }}" required>
                        <label for="admin_email">Email</label>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12 m4">
                        <input id="admin_password" name="admin_password" type="password" required>
                        <label for="admin_password">Password (min 8 chars)</label>
                    </div>
                    <div class="input-field col s12 m4">
                        <input id="admin_password2" name="admin_password2" type="password" required>
                        <label for="admin_password2">Confirm Password</label>
                    </div>
                </div>

                <div class="row">
                    <div class="col s12">
                        <button type="submit" class="btn btn-large green darken-3 waves-effect waves-light">
                            <i class="material-icons left">install_desktop</i>
                            Install Phorum
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
    {% endif %}

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
<script>M.AutoInit();</script>
</body>
</html>

<!DOCTYPE html>
<html lang="{{ lang_locale|default('en') }}" dir="{{ lang_dir|default('ltr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ site_name|default('Phorum') }}{% endblock %}</title>
    <link rel="stylesheet" href="{{ path('/theme/' ~ theme ~ '/phorum.css') }}">
    <link rel="stylesheet" href="{{ path('/assets/vendor/font-awesome/css/font-awesome.min.css') }}">
    {% if impersonating %}
    <style>
        .impersonation-banner {
            background: #e65100;
            color: #fff;
            padding: 8px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 8px;
        }
        .impersonation-banner form { margin: 0; }
        .impersonation-banner button {
            background: #fff;
            color: #e65100;
            border: none;
            padding: 4px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 600;
        }
    </style>
    {% endif %}
    {% if site_read_only %}
    <style>
        .site-status-banner {
            background: #f9a825;
            color: #000;
            padding: 8px 16px;
            text-align: center;
        }
    </style>
    {% endif %}
    {{ hook('css_register') }}
    {{ hook('css_filter') }}
    {% block head %}{% endblock %}
</head>
<body>
    {% if impersonating %}
        <div class="impersonation-banner" role="alert">
            <span>Viewing as {{ user.display_name ?: user.username }} — impersonated by {{ impersonator.display_name ?: impersonator.username }}.</span>
            <form method="post" action="{{ path('/admin/stop-impersonating') }}">
                {{ csrf_field() }}
                <button type="submit">Stop Impersonating</button>
            </form>
        </div>
    {% endif %}
    {% if site_read_only %}
        <div class="site-status-banner" role="status">{{ trans('banner.read_only') }}</div>
    {% endif %}
    <a class="skip-link" href="#main-content">{{ trans('nav.skip_to_content') }}</a>
    {{ hook('start_output') }}{{ hook('start_output_') }}
    <div id="phorum-wrap">
        <nav id="phorum-nav" aria-label="{{ trans('nav.primary') }}">
            {% block nav %}
                <button type="button" class="nav-toggle" aria-expanded="false" aria-controls="phorum-nav-list">
                    <span class="nav-toggle-icon" aria-hidden="true"></span>
                    {{ trans('nav.menu') }}
                </button>
                <ul class="nav-list" id="phorum-nav-list">
                    <li><a href="{{ path('/') }}"><i class="fa fa-home"></i>{{ trans('nav.forum_index') }}</a></li>
                    <li><a href="{{ path('/search') }}"><i class="fa fa-search"></i>{{ trans('nav.search') }}</a></li>
                    {% if user is defined and user %}
                        <li><a href="{{ path('/pm') }}"><i class="fa fa-envelope-o"></i>{{ trans('nav.messages') }}{% if user.pm_new_count > 0 %} <span class="pm-badge">{{ user.pm_new_count }}</span>{% endif %}</a></li>
                        <li><a href="{{ path('/user/' ~ user.user_id) }}"><i class="fa fa-user"></i>{{ user.display_name ?: user.username }}</a></li>
                        <li><a href="{{ path('/user/settings') }}"><i class="fa fa-cog"></i>{{ trans('nav.settings') }}</a></li>
                        <li><a href="{{ path('/logout') }}"><i class="fa fa-sign-out"></i>{{ trans('nav.log_out') }}</a></li>
                    {% else %}
                        <li><a href="{{ path('/login') }}"><i class="fa fa-sign-in"></i>{{ trans('nav.log_in') }}</a></li>
                        <li><a href="{{ path('/register') }}"><i class="fa fa-user-plus"></i>{{ trans('nav.register') }}</a></li>
                    {% endif %}
                </ul>
            {% endblock %}
        </nav>
        {{ hook('after_header') }}{{ hook('after_header_') }}

        <main id="main-content">
            {% block content %}{% endblock %}
        </main>

        {{ hook('before_footer') }}{{ hook('before_footer_') }}
        <footer id="phorum-footer">
            <p><a href="https://www.phorum.org/">{{ trans('nav.powered_by') }}</a></p>
        </footer>
    </div>
    <div id="attachment-lightbox" class="lightbox-overlay" hidden>
        <button type="button" class="lightbox-close" aria-label="{{ trans('attachment.lightbox_close') }}">&times;</button>
        <img src="" alt="">
    </div>

    {{ hook('javascript_filter') }}
    {{ hook('end_output') }}{{ hook('end_output_') }}
    {% block scripts %}
        <script>
            (function () {
                var toggle = document.querySelector('.nav-toggle');
                var list = document.getElementById('phorum-nav-list');
                if (!toggle || !list) {
                    return;
                }
                toggle.addEventListener('click', function () {
                    var isOpen = list.classList.toggle('is-open');
                    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                });
            })();

            (function () {
                var dropdowns = document.querySelectorAll('.mod-dropdown');
                if (!dropdowns.length) {
                    return;
                }

                function closeDropdown(dropdown) {
                    dropdown.classList.remove('is-open');
                    var toggle = dropdown.querySelector('.mod-dropdown-toggle');
                    if (toggle) {
                        toggle.setAttribute('aria-expanded', 'false');
                    }
                }

                function adjustDropdownPosition(dropdown) {
                    var menu = dropdown.querySelector('.mod-dropdown-menu');
                    if (!menu) {
                        return;
                    }
                    
                    // Reset position styles to get natural positioning
                    menu.style.left = '';
                    menu.style.right = '';
                    
                    var rect = menu.getBoundingClientRect();
                    var viewportWidth = window.innerWidth || document.documentElement.clientWidth;
                    
                    // Check if dropdown extends beyond right edge of viewport
                    if (rect.right > viewportWidth) {
                        menu.style.left = 'auto';
                        menu.style.right = '0';
                    }
                    
                    // Check if dropdown extends beyond left edge of viewport
                    if (rect.left < 0) {
                        menu.style.right = 'auto';
                        menu.style.left = '0';
                    }
                }

                dropdowns.forEach(function (dropdown) {
                    var toggle = dropdown.querySelector('.mod-dropdown-toggle');
                    if (!toggle) {
                        return;
                    }
                    toggle.addEventListener('click', function (event) {
                        event.stopPropagation();
                        var isOpen = dropdown.classList.toggle('is-open');
                        toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                        
                        if (isOpen) {
                            adjustDropdownPosition(dropdown);
                        }
                    });
                });

                document.addEventListener('click', function (event) {
                    dropdowns.forEach(function (dropdown) {
                        if (!dropdown.contains(event.target)) {
                            closeDropdown(dropdown);
                        }
                    });
                });

                document.addEventListener('keydown', function (event) {
                    if (event.key === 'Escape') {
                        dropdowns.forEach(closeDropdown);
                    }
                });
            })();

            (function () {
                var lightbox = document.getElementById('attachment-lightbox');
                if (!lightbox) {
                    return;
                }
                var img   = lightbox.querySelector('img');
                var close = lightbox.querySelector('.lightbox-close');

                function openLightbox(link) {
                    img.src = link.getAttribute('href');
                    img.alt = link.getAttribute('data-lightbox-name') || '';
                    lightbox.hidden = false;
                }

                function closeLightbox() {
                    lightbox.hidden = true;
                    img.src = '';
                }

                document.addEventListener('click', function (event) {
                    var link = event.target.closest('.attachment-preview-link');
                    if (link) {
                        event.preventDefault();
                        openLightbox(link);
                        return;
                    }
                    if (!lightbox.hidden && (event.target === lightbox || event.target === close)) {
                        closeLightbox();
                    }
                });

                document.addEventListener('keydown', function (event) {
                    if (event.key === 'Escape' && !lightbox.hidden) {
                        closeLightbox();
                    }
                });
            })();
        </script>
    {% endblock %}
</body>
</html>

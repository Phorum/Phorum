{% extends 'base.html.twig' %}

{% block title %}{{ trans('mod.queue_title') }} &mdash; {{ site_name }}{% endblock %}

{% block content %}
<nav class="breadcrumb" aria-label="{{ trans('nav.breadcrumb') }}">
    <a href="{{ path('/') }}">{{ trans('nav.forum_index') }}</a> &rsaquo;
    {{ trans('mod.queue_title') }}
</nav>

<h1>{{ trans('mod.queue_title') }}</h1>

{% if pending is empty %}
    <p>{{ trans('mod.queue_empty') }}</p>
{% else %}
    {% for item in pending %}
        <article class="message message-unapproved" id="msg-{{ item.message_id }}">
            <header class="message-header">
                <div class="msg-author-info">
                    <div class="msg-author-line">
                        <span class="message-author">{{ item.author }}</span>
                        <span class="unapproved-badge">{{ trans('message.awaiting_approval') }}</span>
                    </div>
                    <div class="msg-subject-line">{{ item.subject }}</div>
                    <div class="msg-date-line">
                        {{ trans('mod.queue_forum') }}: {{ forum_names[item.forum_id]|default('#' ~ item.forum_id) }}
                        &mdash; {{ trans('mod.queue_posted') }} {{ item.datestamp|relative_time }}
                    </div>
                </div>
            </header>

            <div class="message-body">
                {{ item.body|format(item.meta) }}
            </div>

            <footer class="message-footer">
                <span class="mod-actions">
                    <a href="{{ path('/moderate/message/' ~ item.message_id ~ '/approve') }}">{{ trans('message.approve') }}</a>
                    <a href="{{ path('/moderate/message/' ~ item.message_id ~ '/delete') }}">{{ trans('message.delete') }}</a>
                </span>
            </footer>
        </article>
    {% endfor %}
{% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ message.subject|e }} &mdash; {{ trans('pm.private_messages') }} &mdash; {{ site_name }}{% endblock %}

{% block content %}
<div id="pm-layout">
    {% include 'pm/_sidebar.html.twig' %}

    <section id="pm-content">
        <div class="pm-read">
            {% include 'pm/_message.html.twig' with {message: message, sender: sender, recipients: recipients} only %}

            <div class="pm-read-actions">
                <a class="button" href="{{ path('/pm/compose/' ~ message.user_id ~ '?reply=' ~ xref.pm_xref_id) }}">{{ trans('pm.reply') }}</a>
                <a href="{{ path('/pm/delete/' ~ xref.pm_xref_id) }}">{{ trans('pm.delete') }}</a>
                {% if folders is not empty %}
                    <form method="post" action="{{ path('/pm/move/' ~ xref.pm_xref_id) }}" style="display:inline">
                        {{ csrf_field() }}
                        <select name="pm_folder_id">
                            <option value="">{{ trans('pm.move_to_folder') }}</option>
                            {% for f in folders %}
                                <option value="{{ f.pm_folder_id }}">{{ f.foldername|e }}</option>
                            {% endfor %}
                        </select>
                        <button type="submit">{{ trans('pm.move') }}</button>
                    </form>
                {% endif %}
                <a href="{{ path('/pm') }}">{{ trans('pm.back_to_inbox') }}</a>
            </div>
        </div>
    </section>
</div>
{% endblock %}

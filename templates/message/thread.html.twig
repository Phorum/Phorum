{% extends 'base.html.twig' %}

{% block title %}{{ root.subject }} &mdash; {{ forum.name }} &mdash; {{ site_name }}{% endblock %}
{% block head %}
    {% set canonical_url = absolute_url(pagination_url(base_url, page)) %}
    <link rel="canonical" href="{{ canonical_url }}">
    {% if page > 1 %}<link rel="prev" href="{{ absolute_url(pagination_url(base_url, page - 1)) }}">{% endif %}
    {% if page < pages %}<link rel="next" href="{{ absolute_url(pagination_url(base_url, page + 1)) }}">{% endif %}
    <meta property="og:site_name" content="{{ site_name }}">
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ root.subject }}">
    {% if json_ld[0].text %}
        <meta property="og:description" content="{{ json_ld[0].text|slice(0, 200) }}{% if json_ld[0].text|length > 200 %}&hellip;{% endif %}">
    {% endif %}
    <meta property="og:url" content="{{ json_ld[0].url }}">
    {% if feeds_enabled %}
        <link rel="alternate" type="application/rss+xml" title="{{ root.subject }} — RSS" href="{{ absolute_url('/forum/' ~ forum.forum_id ~ '/thread/' ~ root.message_id ~ '/feed.rss') }}">
        <link rel="alternate" type="application/atom+xml" title="{{ root.subject }} — Atom" href="{{ absolute_url('/forum/' ~ forum.forum_id ~ '/thread/' ~ root.message_id ~ '/feed.atom') }}">
        <link rel="alternate" type="application/feed+json" title="{{ root.subject }} — JSON Feed" href="{{ absolute_url('/forum/' ~ forum.forum_id ~ '/thread/' ~ root.message_id ~ '/feed.json') }}">
    {% endif %}
    {{ json_ld(json_ld) }}
{% endblock %}

{% block content %}
<nav class="breadcrumb" aria-label="{{ trans('nav.breadcrumb') }}">
    <a href="{{ path('/') }}">{{ trans('nav.forum_index') }}</a> &rsaquo;
    <a href="{{ path('/forum/' ~ forum.forum_id) }}">{{ forum.name }}</a> &rsaquo;
    {{ root.subject }}
</nav>

<div class="thread-header">
    <h1>{{ root.subject }}</h1>
    <div class="thread-actions">
        {% if can_reply %}
            <a href="{{ path('/forum/' ~ forum.forum_id ~ '/post?reply=' ~ root.message_id) }}" class="btn-post"><i class="fa fa-reply"></i>{{ trans('thread.reply') }}</a>
        {% endif %}
        {% if user is defined and user %}
            {% if current_sub != SUB_NONE %}
                <a href="{{ path('/follow/' ~ root.message_id) }}" class="btn-follow btn-follow-active"><i class="fa fa-bell"></i>{{ trans('thread.following') }}</a>
            {% else %}
                <a href="{{ path('/follow/' ~ root.message_id) }}" class="btn-follow"><i class="fa fa-bell"></i>{{ trans('thread.follow') }}</a>
            {% endif %}
        {% endif %}
        {% if feeds_enabled %}
            <a href="{{ path('/forum/' ~ forum.forum_id ~ '/thread/' ~ root.message_id ~ '/feed.rss') }}" class="btn-feed"><i class="fa fa-rss"></i>{{ trans('forum.feed_link') }}</a>
        {% endif %}
        {% if can_moderate or can_moderate_users %}
            <div class="mod-dropdown">
                <button type="button" class="btn-mod mod-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                    <i class="fa fa-gavel"></i>{{ trans('mod.moderate') }} <i class="fa fa-caret-down"></i>
                </button>
                <div class="mod-dropdown-menu">
                    {% if can_moderate %}
                        <a href="{{ path('/moderate/queue') }}">{{ trans('mod.queue') }}</a>
                        <a href="{{ path('/moderate/reports') }}">{{ trans('mod.reports_title') }}</a>
                        {% if root.closed %}
                            <a href="{{ path('/moderate/thread/' ~ root.message_id ~ '/open') }}">{{ trans('thread.reopen') }}</a>
                        {% else %}
                            <a href="{{ path('/moderate/thread/' ~ root.message_id ~ '/close') }}">{{ trans('thread.close') }}</a>
                        {% endif %}
                        {% if root.sort == 1 %}
                            <a href="{{ path('/moderate/thread/' ~ root.message_id ~ '/unsticky') }}">{{ trans('thread.unsticky') }}</a>
                        {% else %}
                            <a href="{{ path('/moderate/thread/' ~ root.message_id ~ '/sticky') }}">{{ trans('thread.sticky') }}</a>
                        {% endif %}
                        <a href="{{ path('/moderate/thread/' ~ root.message_id ~ '/move') }}">{{ trans('thread.move') }}</a>
                        <a href="{{ path('/moderate/thread/' ~ root.message_id ~ '/merge') }}">{{ trans('thread.merge') }}</a>
                        <a href="{{ path('/moderate/thread/' ~ root.message_id ~ '/delete') }}" class="mod-dropdown-danger">{{ trans('thread.delete') }}</a>
                    {% endif %}
                    {% if can_moderate_users %}
                        <a href="{{ path('/moderate/users') }}">{{ trans('mod.users_queue') }}</a>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>
</div>

{% if announcements %}
    {% include 'announcements/_box.html.twig' %}
{% endif %}

{% set current_user_id = user.user_id|default(0) %}

{% if threaded %}
    {% import _self as macros %}
    {% for msg in messages %}
        {{ macros.message_node(msg, forum, can_reply, can_moderate, can_view_attachments, new_ids|default([]), current_user_id, users_map|default({}), track_edits|default(false), can_edit_ids|default([])) }}
    {% endfor %}
{% else %}
    {% for msg in messages %}
        {% include 'message/_post.html.twig' with {msg: msg, forum: forum, can_reply: can_reply, can_moderate: can_moderate, can_view_attachments: can_view_attachments, new_ids: new_ids|default([]), current_user_id: current_user_id, track_edits: track_edits|default(false), users_map: users_map|default({}), can_edit_ids: can_edit_ids|default([])} %}
    {% endfor %}
{% endif %}

{% include '_pagination.html.twig' %}

{% macro message_node(msg, forum, can_reply, can_moderate, can_view_attachments, new_ids, current_user_id, users_map, track_edits, can_edit_ids) %}
    {% import _self as macros %}
    {% include 'message/_post.html.twig' with {msg: msg, forum: forum, can_reply: can_reply, can_moderate: can_moderate, can_view_attachments: can_view_attachments, new_ids: new_ids, current_user_id: current_user_id, users_map: users_map, track_edits: track_edits, can_edit_ids: can_edit_ids} %}
    {% if msg.children %}
        <div class="thread-replies">
            {% for child in msg.children %}
                {{ macros.message_node(child, forum, can_reply, can_moderate, can_view_attachments, new_ids, current_user_id, users_map, track_edits, can_edit_ids) }}
            {% endfor %}
        </div>
    {% endif %}
{% endmacro %}
{% endblock %}

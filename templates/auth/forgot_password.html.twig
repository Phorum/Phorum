{% extends 'base.html.twig' %}

{% block title %}{{ trans('auth.forgot_title') }} &mdash; {{ site_name }}{% endblock %}

{% block content %}
<h1>{{ trans('auth.forgot_title') }}</h1>

{% if sent %}
    <p class="success">{{ trans('auth.forgot_sent') }}</p>
{% else %}
    {% include '_form_errors.html.twig' %}

    <form method="post" action="{{ path('/forgot-password') }}">
        {{ csrf_field() }}

        <div class="form-row">
            <label for="email">{{ trans('auth.forgot_email_label') }}</label>
            <input type="email" id="email" name="email" required autofocus autocomplete="email"
                   value="{{ _post.email|default('')|e }}">
        </div>

        <div class="form-row">
            <button type="submit">{{ trans('auth.forgot_submit') }}</button>
        </div>
    </form>
{% endif %}

<p><a href="{{ path('/login') }}">{{ trans('auth.login_link') }}</a></p>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ trans('force_password_change.title') }} &mdash; {{ site_name }}{% endblock %}

{% block content %}
<h1>{{ trans('force_password_change.title') }}</h1>

<div class="info-box">{{ trans('force_password_change.message') }}</div>

{% include '_form_errors.html.twig' %}

<form method="post" action="{{ path('/user/change-password') }}" class="settings-form">
    {{ csrf_field() }}
    <input type="hidden" name="redirect" value="{{ redirect|e }}">

    <fieldset>
        <legend class="bar-accent">{{ trans('force_password_change.title') }}</legend>

        <div class="form-row">
            <label for="password">{{ trans('force_password_change.new_password') }}</label>
            <input type="password" id="password" name="password" autocomplete="new-password" required>
        </div>

        <div class="form-row">
            <label for="password2">{{ trans('force_password_change.confirm_password') }}</label>
            <input type="password" id="password2" name="password2" autocomplete="new-password" required>
        </div>
    </fieldset>

    <div class="form-actions">
        <button type="submit" class="btn-post">{{ trans('force_password_change.save') }}</button>
    </div>
</form>
{% endblock %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ trans('upgrade.page_title') }}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <style>
        body  { background: #f5f5f5; }
        .brand-logo { font-size: 1.4rem !important; }
        nav   { background-color: #2e7d32; }
        .card { margin-top: 24px; }
    </style>
</head>
<body>
<nav>
    <div class="nav-wrapper container">
        <span class="brand-logo">{{ trans('upgrade.page_title') }}</span>
    </div>
</nav>

<div class="container">

    <div class="card">
        <div class="card-content">
            <span class="card-title">{{ trans('upgrade.detected_heading') }}</span>
            <p>
                {{ trans('upgrade.detected_message') }}
            </p>

            {% if pending_tables is empty and pending_patches is empty %}
                <p class="grey-text">{{ trans('upgrade.up_to_date') }}</p>
            {% endif %}

            {% if pending_tables is not empty %}
                <p>{{ trans('upgrade.new_tables_heading') }}</p>
                <ul class="browser-default">
                    {% for table in pending_tables %}
                        <li><code>{{ table }}</code></li>
                    {% endfor %}
                </ul>
            {% endif %}

            {% if pending_patches is not empty %}
                <p>{{ trans('upgrade.new_patches_heading') }}</p>
                <ul class="browser-default">
                    {% for patch in pending_patches %}
                        <li>{{ patch }}</li>
                    {% endfor %}
                </ul>
            {% endif %}

            <form method="post" action="{{ path('/upgrade') }}">
                {{ csrf_field() }}
                <div class="row" style="margin-top:16px">
                    <div class="col s12">
                        <button type="submit" class="btn btn-large green darken-3 waves-effect waves-light">
                            <i class="material-icons left">upgrade</i>
                            {{ trans('upgrade.submit') }}
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>
